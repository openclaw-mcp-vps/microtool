// Reference schema for teams that later migrate from JSON persistence to SQL migrations.
// Runtime persistence in this project intentionally uses filesystem JSON and avoids Prisma codegen.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tool {
  id              String   @id @default(uuid())
  ownerEmail      String
  name            String
  subdomain       String   @unique
  description     String
  status          String
  deploymentUrl   String
  monthlyPriceUsd Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Purchase {
  id        String   @id @default(uuid())
  toolId    String
  email     String
  status    String
  orderId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
